{
  "name": "agentcontract",
  "version": "0.1.0",
  "description": "Executable spec for AI agent behavior contracts — define expected behavior in YAML and verify compliance.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agentcontract": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wharfe/agentcontract.git"
  },
  "homepage": "https://github.com/wharfe/agentcontract",
  "keywords": [
    "ai",
    "agent",
    "contract",
    "testing",
    "verification",
    "llm",
    "governance"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "publint": "^0.3.18",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "ajv": "^8.18.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1"
  }
}
